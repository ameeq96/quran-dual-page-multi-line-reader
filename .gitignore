# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.fvm/
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android / local machine files
/android/local.properties
/android/local-maven-repo/
*.jks
*.keystore

# iOS / macOS generated files
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/
**/macos/Flutter/ephemeral/

# Windows / Linux generated files
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# Local run logs
*.stdout.log
*.stderr.log

# Local source/reference assets not needed in git
/source_pdfs/

# Heavy local Quran scan folders kept outside git
/assets/quran_pages/10_line/*
!/assets/quran_pages/10_line/.gitkeep
/assets/quran_pages/13_line/*
!/assets/quran_pages/13_line/.gitkeep
/assets/quran_pages/14_line/*
!/assets/quran_pages/14_line/.gitkeep
/assets/quran_pages/15_line/*
!/assets/quran_pages/15_line/.gitkeep
/assets/quran_pages/16_line/*
!/assets/quran_pages/16_line/.gitkeep
/assets/quran_pages/17_line/*
!/assets/quran_pages/17_line/.gitkeep
/assets/quran_pages/kanzul_iman/*
!/assets/quran_pages/kanzul_iman/.gitkeep

# Local asset packs (large) kept outside git
/assets/asset_packs/
